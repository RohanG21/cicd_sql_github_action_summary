
name: gemini_cli_sql_summary

# Controls when the workflow will run
on:
  # Triggers the workflow on push or pull request events but only for the "main" branch
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

  # Allows you to run this workflow manually from the Actions tab
  workflow_dispatch:
permissions:
  contents: write
# A workflow run is made up of one or more jobs that can run sequentially or in parallel
jobs:
  build:
    # The type of runner that the job will run on
    runs-on: ubuntu-latest

    # Steps represent a sequence of tasks that will be executed as part of the job
    steps:
      # Checks-out your repository under $GITHUB_WORKSPACE, so your job can access it
      - name: checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 2
      - name: get SQL diff
        id: diff
        run: | 
          git diff HEAD~1 HEAD -- '*.sql' > diff.sql || echo "" > diff.sql
          {
           echo "sql_diff<<EOF"
           cat diff.sql
           echo "EOF"
          } >> "$GITHUB_OUTPUT"
      - name: run Gemini CLI
        id: gemini 
        uses: google-github-actions/run-gemini-cli@v0.1.3
        with:
          prompt: | 
            You are a Senior Data Engineer. Summarize the following SQL changes. Focus on table schema updates, new indexes, or logic changes

            Code Diff: 
            ${{steps.diff.outputs.sql_diff}}
      - name: save summary
        run: | 
           echo "${{ steps.gemini.outputs.response }}" > sql_file_summary.txt

      - name: configure git 
        run: | 
          git config user.name "RohanG21"
          git config user.email "rohanng2020@gmail.com"
      - name: push summary 
        run: |
          git add sql_file_summary.txt
          git commit -m "created a new summary file for sql code that was recently pushed"
          git push 
       
       
       
     
          
