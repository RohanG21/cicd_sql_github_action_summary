
name: gemini_cli_sql_summary

# Controls when the workflow will run
on:
  # Triggers the workflow on push or pull request events but only for the "main" branch
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch:
jobs:
  summarize-changes:
    # The type of runner that the job will run on
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      # Checks-out your repository under $GITHUB_WORKSPACE, so your job can access it
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          fetch-depth: 2
      - name: get SQL diff
        id: diff_check
        run: | 
           DIFF=$(git diff HEAD^ HEAD -- '**.sql')

           if [ -z "$DIFF" ]; then
              echo "No relevant SQL changes found."
              echo "has_changes=false" >> "$GITHUB_OUTPUT"
            else
              echo "has_changes=true" >> "$GITHUB_OUTPUT"
              {
                echo "sql_diff<<EOF"
                echo "$DIFF"
                echo "EOF"
              } >> "$GITHUB_OUTPUT"
            fi
      
      - name: run Gemini CLI
        if: steps.diff_check.outputs.has_changes == 'true'
        id: gemini
        uses: google-github-actions/run-gemini-cli@v0.1.3
        with:
           google_api_key: ${{ secrets.GEMINI_API_KEY }}
           prompt: |
            You are a senior Data Engineer. Analyze the following SQL code diff. 
            Summarize what changed, focusing on:
            1. Schema modifications (ALTER, CREATE, DROP).
            2. Significant logic changes in CTEs or JOINs
            3. New indexes or constraints

            keep the summary concise and technical
            
            CODE DIFF: 
            ${{ steps.diff_check.outputs.sql_diff }}
      - name: save summary
        if: steps.diff_check.outputs.has_changes == 'true'
        run: | 
           echo "${{ steps.gemini.outputs.text }}" >> sql_changes_summary.md
           git config --global user.name "github-actions[bot]"
           git config --global user.email "github-actions[bot]@users.noreply.github.com"
           git add sql_changes_summary.md
           git commit -m "docs: automated sql summary update [skip ci]" 
           git push
